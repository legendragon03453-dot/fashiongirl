rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: 
     * This ruleset implements a CMS-style security model for the FashionGirl Blog. 
     * All content (Posts, Products, Categories, Authors, Pages, and Carousel Slides) 
     * is publicly readable to allow for SEO and unrestricted browsing by visitors. 
     *
     * Data Structure:
     * The database uses a flat, top-level collection structure for primary entities, 
     * optimized for direct access and simplified querying.
     *
     * Key Security Decisions:
     * 1. Public Reads: Global read access is granted to all content collections 
     *    as per the "Authorization Independence" strategy.
     * 2. Role-Based Writes: All write operations (create, update, delete) are 
     *    restricted to users verified as administrators.
     * 3. Role Verification: Admin status is determined by the presence of a 
     *    document in the `/roles_admin/` collection.
     * 4. Relational Integrity: On creation, documents must include an internal 
     *    'id' field that matches the document ID in the path to ensure consistency.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has an entry in the admin roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Verifies the user is an admin and the target document exists for modification.
     */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    /**
     * @description Ensures the provided data ID matches the document path ID.
     */
    function matchesPathId(dataId, pathId) {
      return dataId == pathId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for author profiles. Publicly readable, admin-managed.
     * @path /authors/{authorId}
     * @allow (get) Any user.
     * @deny (update) Any user not in the /roles_admin collection.
     * @principle Implements role-based access control for administrative actions.
     */
    match /authors/{authorId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(request.resource.data.id, authorId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for content categories. Used for navigation and site structure.
     * @path /categories/{categoryId}
     * @allow (list) Any user browsing the site.
     * @deny (create) Anonymous or non-admin users.
     * @principle Ensures static site configuration remains read-only for the public.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(request.resource.data.id, categoryId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for blog articles. The primary content of the application.
     * @path /blogPosts/{blogPostId}
     * @allow (get) Any reader.
     * @deny (delete) A user who is authenticated but not an admin.
     * @principle Protects public content from unauthorized modification while maximizing availability.
     */
    match /blogPosts/{blogPostId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(request.resource.data.id, blogPostId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for the product showcase catalog.
     * @path /products/{productId}
     * @allow (list) Any user viewing the product gallery.
     * @deny (update) Users attempting to change affiliate or purchase links without admin rights.
     * @principle Validates relational integrity by locking the internal ID on update.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(request.resource.data.id, productId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for managing homepage carousel slides.
     * @path /heroCarouselSlides/{slideId}
     * @allow (get) Any visitor loading the homepage.
     * @deny (create) Any user not authenticated as an admin.
     * @principle Restricts high-visibility UI components to administrative control.
     */
    match /heroCarouselSlides/{slideId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(request.resource.data.id, slideId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for static pages (About Us, FAQ, etc.).
     * @path /pages/{pageId}
     * @allow (get) All public traffic.
     * @deny (update) Any non-admin user.
     * @principle Maintains the integrity of static informational content.
     */
    match /pages/{pageId} {
      allow get, list: if true;
      allow create: if isAdmin() && matchesPathId(request.resource.data.id, pageId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Internal roles collection. 
     * @path /roles_admin/{userId}
     * @allow (get) Authenticated users checking their own status.
     * @deny (write) Any client-side request. Roles should be managed via Admin SDK/Console.
     * @principle Protects the source of truth for administrative authorization.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update, delete: if false;
    }
  }
}