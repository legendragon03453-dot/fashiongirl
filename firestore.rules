rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - FASHIONGIRL BLOG & CRM
     *
     * Core Philosophy:
     * This ruleset implements a robust "Global Admin Role" model to support a public fashion blog 
     * and a private administrative CRM (/painel). It prioritizes Authorization Independence 
     * by decoupling content access from complex ownership trees, relying instead on a 
     * centralized roles collection.
     *
     * Data Structure:
     * - Public Content: /authors, /categories, /blog_posts, /products, /carousel_slides.
     * - Authorization Data: /roles_admin/{userId}.
     *
     * Key Security Decisions:
     * 1. Public Read Access: All blog and product content is globally readable (get and list) 
     *    to ensure maximum performance and SEO friendliness for unauthenticated visitors.
     * 2. Administrative Write Access: Every create, update, and delete operation across the 
     *    entire database is restricted to users whose UID exists in the /roles_admin collection.
     * 3. Authorization Independence: Admin status is verified via an atomic exists() check 
     *    on the /roles_admin collection, preventing "permission leakage" from document-level data.
     *
     * Denormalization for Authorization:
     * To support the CRM's /painel functionality, the system uses a high-performance DBAC 
     * (Database Access Control) pattern. By using the User's UID as the document ID in 
     * /roles_admin, the rules can verify permissions with a single, cached lookup without 
     * needing to query document fields.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Verifies if the authenticated user is registered as an administrator. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Ensures the user is an admin and the document being modified/deleted exists. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for global admin role definitions.
     * @path /roles_admin/{userId}
     * @allow (get) Admin user reads their own or another admin's role status.
     * @deny (create) Unauthenticated user attempts to grant themselves admin rights.
     * @principle Structural Segregation: Keeps authorization logic separate from application data.
     */
    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for blog post authors.
     * @path /authors/{authorId}
     * @allow (get, list) Public visitor views the list of authors.
     * @deny (update) Non-admin user attempts to change an author's bio.
     * @principle Global Role-Based Writes: Restricts data modifications to verified staff.
     */
    match /authors/{authorId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for blog and product categories.
     * @path /categories/{categoryId}
     * @allow (get, list) Any user browses categories like "Estilo" or "Tendências".
     * @deny (create) Authenticated non-admin user attempts to add a new category.
     * @principle Public Read with Owner-Only Writes (Admin-as-Owner).
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for individual blog articles.
     * @path /blog_posts/{blogPostId}
     * @allow (get) Unauthenticated visitor reads a specific article.
     * @deny (delete) Any user without admin privileges tries to remove a post.
     * @principle High-Performance List: Public list allows for efficient fetching of the feed.
     */
    match /blog_posts/{blogPostId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for fashion products in the catalog.
     * @path /products/{productId}
     * @allow (list) Public user scrolls through the product catalog.
     * @deny (update) Attempting to change a product price without admin status.
     * @principle Administrative Data Control: Protects commercial data integrity.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for homepage carousel slides.
     * @path /carousel_slides/{slideId}
     * @allow (get) All users see the hero carousel on the homepage.
     * @deny (create) Malicious user attempts to inject a slide with an external link.
     * @principle Strict Operational Security: Only admins manage marketing materials.
     */
    match /carousel_slides/{slideId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }
  }
}